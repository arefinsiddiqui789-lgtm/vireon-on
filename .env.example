# Database — PostgreSQL connection string
# For Vercel: Use Vercel Postgres or Neon
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/vireon?sslmode=require"

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"

# NextAuth URL — your deployed domain
# For Vercel: https://your-app.vercel.app
NEXTAUTH_URL="https://your-app.vercel.app"

# AI Configuration — Required for Vireon Bro & Code Compiler on Vercel
# Works with Google Gemini (free, recommended) or any OpenAI-compatible provider

# === OPTION A: Google Gemini (FREE, recommended) ===
# Get your key at: https://aistudio.google.com/apikey
AI_BASE_URL="https://generativelanguage.googleapis.com"
AI_API_KEY="your-gemini-api-key-here"
AI_MODEL="gemini-2.0-flash"

# === OPTION B: Groq (free) ===
# AI_BASE_URL="https://api.groq.com/openai/v1"
# AI_API_KEY="gsk_your-key-here"
# AI_MODEL="llama-3.3-70b-versatile"

# === OPTION C: OpenRouter ===
# AI_BASE_URL="https://openrouter.ai/api/v1"
# AI_API_KEY="sk-or-your-key-here"
# AI_MODEL="meta-llama/llama-3.3-70b-instruct:free"
